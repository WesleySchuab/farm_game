; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[application]

config/name="fallen_realm2"
run/main_scene="uid://6ann8q8qx82y"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"

[autoload]

ToolManager="*res://scripts/globais/tool_manager.gd"
InventoryManager="*res://scripts/globais/inventory_manager.gd"
DayAndCycleManager="*res://scripts/globais/day_and_cycle_manager.gd"
SaveGameManager="*res://scripts/globais/save_game_manager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
GameDialogueManager="*res://scripts/globais/game_dialogue_manager.gd"

[display]

window/size/viewport_width=640
window/size/viewport_height=360
window/size/window_width_override=1280
window/size/window_height_override=720
window/stretch/mode="viewport"
window/stretch/aspect="keep_height"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[file_customization]

folder_colors={
"res://dialogue/": "teal",
"res://game/assets/": "orange",
"res://resources/": "purple",
"res://scenes/": "green",
"res://scripts/": "pink",
"res://tileset/": "yellow"
}

[global_group]

navigation_polygon_source_geometry_group=""
player=""


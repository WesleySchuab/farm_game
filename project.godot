; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="fallen_realm2"
run/main_scene="uid://crfiq1tjsrdgy"
config/features=PackedStringArray("4.5", "Mobile")
config/icon="res://icon.svg"

[audio]

buses/default_bus_layout="uid://cu25fbwj5ayn"

[autoload]

ToolManager="*res://scripts/globais/tool_manager.gd"
InventoryManager="*res://scripts/globais/inventory_manager.gd"
SaveGameManager="*res://scripts/globais/save_game_manager.gd"
DialogueManager="*res://addons/dialogue_manager/dialogue_manager.gd"
GameDialogueManager="*res://scripts/globais/game_dialogue_manager.gd"
GameManager="*res://scripts/globais/game_manager.gd"
SceneManager="*res://scripts/globais/scene_manager.gd"
DayAndNightCycleManager="*res://scripts/globais/day_and_night_cycle_manager.gd"
EventBus="*res://scripts/globais/EventBus.gd"
AudioManager="*res://scripts/globais/audio_manager.gd"

[display]

window/size/viewport_width=680
window/size/viewport_height=480
window/size/mode=2
window/size/window_width_override=1360
window/size/window_height_override=680
window/stretch/mode="canvas_items"
window/stretch/aspect="keep_height"
window/stretch/scale_mode="integer"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

[file_customization]

folder_colors={
"res://audio/": "red",
"res://dialogue/": "teal",
"res://game/assets/": "orange",
"res://game/assets/characters/enemy/": "red",
"res://resources/": "purple",
"res://scenes/": "green",
"res://scripts/": "pink",
"res://tileset/": "yellow"
}

[global_group]

navigation_polygon_source_geometry_group=""
player=""

